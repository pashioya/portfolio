# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for all outgoing emails.
RESEND_FROM_EMAIL=cv@yourdomain.com

# Your own email address — approval links and CV request notifications go here.
OWNER_EMAIL=you@example.com

# Public base URL of your deployment (no trailing slash).
# Used to build the approval link sent to OWNER_EMAIL.
NEXT_PUBLIC_BASE_URL=https://yourportfolio.com

# GitHub Personal Access Token
CV_GITHUB_PAT=CV_GITHUB_PAT_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

CV_GITHUB_URL=https://api.github.com/repos/pashioya/pauls-cv/contents/main.pdf
DB_DIR=./data
